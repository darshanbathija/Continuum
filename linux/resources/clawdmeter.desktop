[Desktop Entry]
Type=Application
Name=Clawdmeter
GenericName=Claude / Codex Usage Meter
Comment=Live rate-limit gauges and $/token analytics for Claude Code + Codex CLI
Exec=/usr/bin/clawdmeter --with-tray
TryExec=/usr/bin/clawdmeter
Icon=clawdmeter
Categories=Utility;Development;Monitor;
Keywords=claude;codex;rate-limit;analytics;tokens;ai;
StartupNotify=true
StartupWMClass=clawdmeter
Terminal=false
SingleMainWindow=true
X-GNOME-UsesNotifications=true
