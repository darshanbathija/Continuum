#!/bin/sh
# AppImage entry point. Resolves the bundled Swift runtime + GTK4 libs,
# then exec's the desktop binary.
#
# Layout of the AppDir:
#   AppDir/
#   ├── AppRun                    (this file)
#   ├── usr/
#   │   ├── bin/clawdmeter         (Swift release binary)
#   │   ├── bin/clawdmeterd        (Swift release binary, headless daemon)
#   │   ├── lib/                   (bundled Swift runtime + libwebkitgtk-6.0 + libvte-2.91-gtk4
#   │   │                           + bubblewrap + xdg-dbus-proxy + GStreamer plugins)
#   │   └── share/                 (.desktop, .appdata.xml, icons)
#   └── clawdmeter.desktop

HERE="$(dirname "$(readlink -f "${0}")")"
export PATH="$HERE/usr/bin:$PATH"
# Avoid a trailing colon when the inbound LD_LIBRARY_PATH is empty: ld.so
# treats an empty path segment as CWD, which would let an attacker preload a
# malicious libfoo.so from the directory the AppImage is launched from.
if [ -n "${LD_LIBRARY_PATH:-}" ]; then
    export LD_LIBRARY_PATH="$HERE/usr/lib:$LD_LIBRARY_PATH"
else
    export LD_LIBRARY_PATH="$HERE/usr/lib"
fi
export XDG_DATA_DIRS="$HERE/usr/share:${XDG_DATA_DIRS:-/usr/share}"

# GTK4 + WebKit asset paths (bundled). Override system paths so the
# AppImage's deps are used even on hosts that have older versions.
export GSETTINGS_SCHEMA_DIR="$HERE/usr/share/glib-2.0/schemas"
export GDK_PIXBUF_MODULEDIR="$HERE/usr/lib/gdk-pixbuf-2.0/2.10.0/loaders"
export GDK_PIXBUF_MODULE_FILE="$HERE/usr/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
export GIO_MODULE_DIR="$HERE/usr/lib/gio/modules"

# Decide which binary to exec: --headless / --daemon → clawdmeterd, else clawdmeter (UI).
case "${1:-}" in
    --headless|--daemon)
        shift
        exec "$HERE/usr/bin/clawdmeterd" "$@"
        ;;
    --version|--help|-h)
        exec "$HERE/usr/bin/clawdmeter" "$@"
        ;;
    *)
        exec "$HERE/usr/bin/clawdmeter" "$@"
        ;;
esac
