{
  "name": "clawdmeter-relay",
  "private": true,
  "version": "0.1.0",
  "description": "Clawdmeter Mac<->iPhone WebSocket relay (Group E2). Cloudflare Worker + Durable Object with per-peer bearer auth, WS Hibernation API, and opaque envelope routing.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.5.41",
    "@cloudflare/workers-types": "4.20260101.0",
    "@types/libsodium-wrappers-sumo": "0.7.8",
    "libsodium-wrappers-sumo": "0.7.15",
    "typescript": "5.6.3",
    "vitest": "2.1.9",
    "wrangler": "3.114.17"
  }
}
