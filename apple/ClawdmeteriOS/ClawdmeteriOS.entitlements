<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Shared with the future ClawdmeteriOSWidgets extension so the widget
	     can read the latest poll snapshots from UserDefaults under this
	     suite name. iOS sandboxes everything uniformly, so a normal
	     App Group works here (unlike on macOS where we needed XPC). -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.LRL8MRH6B4.com.continuum</string>
	</array>
	<!-- Shared Keychain access group: iCloud Keychain syncs the Anthropic
	     OAuth token written by the Mac app into this entry, and the iPhone
	     reads it on first launch — no manual paste required as long as the
	     user has iCloud Keychain on with the same Apple ID. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.continuum</string>
	</array>
	<!-- iCloud Key-Value store for Mac→iOS Codex usage sync. DISABLED on
	     personal-team builds — flip on once we're on a paid Developer
	     Program account. See ClawdmeterMac.entitlements for the full note. -->
	<!--
	<key>com.apple.developer.icloud-services</key>
	<array><string>CloudKit</string></array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array/>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)com.continuum</string>
	-->
</dict>
</plist>
