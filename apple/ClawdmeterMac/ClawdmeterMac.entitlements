<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Dev build: sandbox disabled so we can read Claude Code's Keychain entry.
	     For App Store distribution, re-enable sandbox and either:
	       (a) ship our own OAuth flow + our own Keychain entry, OR
	       (b) request a shared iCloud Keychain access group with Claude Code. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Shared container with the widget extension. App Group is prefixed
	     with the team ID because that's how unsigned-by-Apple developer
	     teams must namespace their groups (paid developer programs can
	     skip the prefix). UsageStore reads via the unprefixed identifier
	     and falls back gracefully if it isn't entitled. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.LRL8MRH6B4.ai.continuum</string>
	</array>
	<!-- Shared Keychain access group: the Mac mirrors Claude Code's OAuth
	     token into an iCloud-synced entry here, the iPhone and Watch read
	     from it with zero user setup. `$(AppIdentifierPrefix)` expands to
	     "<team-id>." at sign time. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)ai.continuum</string>
	</array>
	<!-- iCloud Key-Value store for Mac→iOS Codex usage sync.
	     DISABLED: free / personal Apple Developer teams can't use iCloud
	     capability — Apple gates it to the paid Developer Program ($99/yr).
	     The `UsageCloudMirror` calls in `AppModel.consume` silently no-op
	     without the entitlement, so the iPhone just shows the "Waiting
	     for the Mac app" Codex card. Flip these keys on when the
	     dev team upgrades and the iOS Codex card lights up.
	-->
	<!--
	<key>com.apple.developer.icloud-services</key>
	<array><string>CloudKit</string></array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array/>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)ai.continuum</string>
	-->
</dict>
</plist>
