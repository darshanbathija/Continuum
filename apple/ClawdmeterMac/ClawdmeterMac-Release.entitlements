<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Audit P0 fix: release entitlements with the macOS app sandbox ON.

	  The Debug entitlements (sibling file `ClawdmeterMac.entitlements`)
	  disable the sandbox so dev builds can read Claude Code's Keychain
	  entry directly. That is NOT acceptable for shipped DMGs — sandbox
	  is the platform's strongest containment guarantee and turning it
	  off means any RCE elsewhere (e.g. a compromised bundled Node from
	  the supply-chain fix) gains full-user blast radius (Documents,
	  ~/Library, browser cookies, ssh keys) instead of being contained.

	  Trade-off: with sandbox ON, the "read Claude Code's Keychain entry
	  by group" path won't work unless we either
	    (a) ship our own OAuth flow + own Keychain entry (already
	        implemented via PastedAnthropicTokenProvider), OR
	    (b) request a shared keychain-access-group entitlement with
	        Claude Code (requires Anthropic-side coordination).

	  The pasted-token flow keeps working in the sandboxed build via
	  the keychain-access-groups entry below.
	-->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- The Mac daemon listens on Tailscale CGNAT; the entitlement is
	     required because sandbox blocks all network access otherwise. -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- App group for the widget extension. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.76S62SDSD3.com.clawdmeter</string>
	</array>
	<!-- Pasted-token Keychain entry; shared with the iPhone/Watch via
	     iCloud Keychain (kSecAttrSynchronizable=true). -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.clawdmeter</string>
	</array>

	<!--
	  v0.26.2: Read-only sandbox exceptions for the provider state dirs
	  Clawdmeter needs to inspect.

	  Why: The Codex / Gemini-Antigravity / OpenCode CLIs all write auth
	  bundles, session rollouts, and conversation DBs to the *real*
	  user home (~/.codex/, ~/.gemini/, ~/.local/share/opencode/,
	  ~/Library/Application Support/Antigravity/). With sandbox ON, the
	  app's NSHomeDirectory points at its container — those provider
	  dirs are unreachable, so polling silently throws .unauthenticated
	  ("Re-auth required" in logs) and the Usage tab shows 0% / "resets
	  in —" for every provider except Claude (which has its own
	  PastedAnthropicTokenProvider flow).

	  Scope: READ-ONLY. We never write to these paths — auth rotation,
	  session writes, and SQLite writes are all done by the upstream
	  CLIs running in their own processes outside our sandbox. So even
	  a worst-case RCE in our process can read these files but can't
	  modify auth tokens, plant trojans, or alter session state.

	  Why home-relative-path: lets Apple's TCC / sandbox kernel enforce
	  the prefix at the syscall level (Apple's recommended path for
	  shipped DMG-distributed apps that need narrow filesystem reach
	  beyond their container). Each entry must end in '/' to denote a
	  directory tree.

	  Trade-off vs. full sandbox-off: we lose containment specifically
	  for these four dirs but keep it for everything else — ~/Documents,
	  ~/Pictures, ~/Library/Mail, ~/Library/Messages, browser cookies,
	  SSH keys, etc. all remain outside our blast radius.

	  Trade-off vs. paste-token flow: keeps the UX seamless (no manual
	  token copying per provider) at the cost of a wider filesystem
	  attack surface than the sandbox-pure Anthropic path.
	-->
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<!-- Codex CLI: auth.json, sessions/*.jsonl rollouts (rate_limits source),
		     config.toml, projects/ -->
		<string>/.codex/</string>
		<!-- v0.26.3: Anthropic CLI projects directory — RepoIndex and
		     UsageHistoryLoader walk ~/.claude/projects/<encoded-cwd>/*.jsonl
		     for the "X repos tracked" count + the SPEND OVER TIME chart. -->
		<string>/.claude/</string>
		<!-- Gemini CLI + Antigravity sidecar: antigravity/conversations DB,
		     config/projects, tmp/ -->
		<string>/.gemini/</string>
		<!-- OpenCode CLI: auth.json + per-provider state. opencode honors
		     XDG_DATA_HOME but defaults to ~/.local/share/opencode/. -->
		<string>/.local/share/opencode/</string>
		<!-- Antigravity 2 desktop app: native conversation DB + brain/ dir. -->
		<string>/Library/Application Support/Antigravity/</string>
		<!-- v0.26.3: Clawdmeter's own pre-sandbox state — sessions.json,
		     workspaces.json. Users who ran an older non-sandboxed build
		     have 90+ sessions in the real path; without this exception
		     the new sandboxed app writes to the container instead and
		     forgets every prior session. Read-only is enough; the
		     migration writer will live in the container going forward. -->
		<string>/Library/Application Support/Clawdmeter/</string>
		<!-- v0.28.0: ShellRunner.locateBinary needs to read user-local
		     CLI installs (cursor-agent, claude, etc.) from ~/.local/bin/
		     so the Mac app can spawn them. Read-only is enough; we never
		     install or modify binaries on the user's behalf. -->
		<string>/.local/bin/</string>
		<!-- v0.28.0: Cursor agent CLI config + project state. The
		     CursorTokenProvider reads cursor-agent's keychain entries
		     (cursor-access-token / cursor-refresh-token) via the
		     Security framework (not via this entitlement) but future
		     work that reads ~/.cursor/cli-config.json (for plan auth
		     metadata) needs the file-system grant here. -->
		<string>/.cursor/</string>
	</array>
	<!-- iCloud KV sync — paid Developer Program only. -->
	<!--
	<key>com.apple.developer.icloud-services</key>
	<array><string>CloudKit</string></array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array/>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)com.clawdmeter</string>
	-->
</dict>
</plist>
