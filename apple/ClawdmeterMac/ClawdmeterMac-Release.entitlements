<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Audit P0 fix: release entitlements with the macOS app sandbox ON.

	  The Debug entitlements (sibling file `ClawdmeterMac.entitlements`)
	  disable the sandbox so dev builds can read Claude Code's Keychain
	  entry directly. That is NOT acceptable for shipped DMGs — sandbox
	  is the platform's strongest containment guarantee and turning it
	  off means any RCE elsewhere (e.g. a compromised bundled Node from
	  the supply-chain fix) gains full-user blast radius (Documents,
	  ~/Library, browser cookies, ssh keys) instead of being contained.

	  Trade-off: with sandbox ON, the "read Claude Code's Keychain entry
	  by group" path won't work unless we either
	    (a) ship our own OAuth flow + own Keychain entry (already
	        implemented via PastedAnthropicTokenProvider), OR
	    (b) request a shared keychain-access-group entitlement with
	        Claude Code (requires Anthropic-side coordination).

	  The pasted-token flow keeps working in the sandboxed build via
	  the keychain-access-groups entry below.
	-->
	<!-- v0.29.35: App Sandbox DISABLED (was ON). The sandbox denied every
	     git / tmux / agent-CLI subprocess access to the user's repos AND to
	     the worktree storage root (~/Clawdmeter/workspaces), so Sessions/Code
	     and real-agent Chat could not run at all: git died with "getcwd:
	     Operation not permitted", tmux exited non-zero (ShellError 2), and
	     Chat broadcast reported "only 1 provider spawned". Making it work
	     under the sandbox would require security-scoped bookmarks on every
	     repo + worktree root + read-write exceptions for ~/.claude and
	     ~/.codex — which hollows out the sandbox anyway, since the Claude /
	     Codex agents we launch run arbitrary shell commands in those repos.
	     A DMG-distributed dev tool that orchestrates CLI agents is the same
	     posture as Cursor / VS Code / Warp / iTerm — none sandboxed. Hardened
	     runtime + notarization remain ON. The Debug build was already
	     unsandboxed; this realigns Release. The audit-P0 rationale in the
	     comment above is retained for history but no longer applies. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Sparkle sandbox installer service rendezvous. Required when
	     SUEnableInstallerLauncherService is true in Info.plist. -->
	<key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
	<array>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)-spks</string>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)-spki</string>
	</array>
	<!-- The Mac daemon listens on Tailscale CGNAT; the entitlement is
	     required because sandbox blocks all network access otherwise. -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- App group for the widget extension. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.LRL8MRH6B4.ai.continuum</string>
	</array>
	<!-- Pasted-token Keychain entry; shared with the iPhone/Watch via
	     iCloud Keychain (kSecAttrSynchronizable=true). -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)ai.continuum</string>
	</array>

	<!-- v0.29.20: NSOpenPanel-picked file/folder access. The Add-Repo
	     flow (Open project / Clone destination / Quick Start parent)
	     opens NSOpenPanel for the user to pick a folder. Sandboxed
	     apps without this entitlement either get NO panel at all
	     (powerbox refuses) or get a panel whose returned URL is
	     unreadable. Read-write is required because Quick Start /
	     clone WRITE the new repo into the picked parent. -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>

	<!--
	  v0.26.2: Read-only sandbox exceptions for the provider state dirs
	  Clawdmeter needs to inspect.

	  Why: The Codex / Gemini-Antigravity / OpenCode CLIs all write auth
	  bundles, session rollouts, and conversation DBs to the *real*
	  user home (~/.codex/, ~/.gemini/, ~/.local/share/opencode/,
	  ~/Library/Application Support/Antigravity/). With sandbox ON, the
	  app's NSHomeDirectory points at its container — those provider
	  dirs are unreachable, so polling silently throws .unauthenticated
	  ("Re-auth required" in logs) and the Usage tab shows 0% / "resets
	  in —" for every provider except Claude (which has its own
	  PastedAnthropicTokenProvider flow).

	  Scope: READ-ONLY. We never write to these paths — auth rotation,
	  session writes, and SQLite writes are all done by the upstream
	  CLIs running in their own processes outside our sandbox. So even
	  a worst-case RCE in our process can read these files but can't
	  modify auth tokens, plant trojans, or alter session state.

	  Why home-relative-path: lets Apple's TCC / sandbox kernel enforce
	  the prefix at the syscall level (Apple's recommended path for
	  shipped DMG-distributed apps that need narrow filesystem reach
	  beyond their container). Each entry must end in '/' to denote a
	  directory tree.

	  Trade-off vs. full sandbox-off: we lose containment specifically
	  for these four dirs but keep it for everything else — ~/Documents,
	  ~/Pictures, ~/Library/Mail, ~/Library/Messages, browser cookies,
	  SSH keys, etc. all remain outside our blast radius.

	  Trade-off vs. paste-token flow: keeps the UX seamless (no manual
	  token copying per provider) at the cost of a wider filesystem
	  attack surface than the sandbox-pure Anthropic path.
	-->
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<!-- Codex CLI: auth.json, sessions/*.jsonl rollouts (rate_limits source),
		     config.toml, projects/ -->
		<string>/.codex/</string>
		<!-- v0.26.3: Anthropic CLI projects directory — RepoIndex and
		     UsageHistoryLoader walk ~/.claude/projects/<encoded-cwd>/*.jsonl
		     for the "X repos tracked" count + the SPEND OVER TIME chart. -->
		<string>/.claude/</string>
		<!-- Gemini CLI + Antigravity sidecar: antigravity/conversations DB,
		     config/projects, tmp/ -->
		<string>/.gemini/</string>
		<!-- OpenCode CLI: auth.json + per-provider state. opencode honors
		     XDG_DATA_HOME but defaults to ~/.local/share/opencode/. -->
		<string>/.local/share/opencode/</string>
		<!-- Antigravity 2 desktop app: native conversation DB + brain/ dir. -->
		<string>/Library/Application Support/Antigravity/</string>
		<!-- Cursor desktop app: hook logs include per-generation model,
		     token, and workspace metadata used for Cursor analytics /
		     tokens-by-model history. Read-only is enough; Continuum
		     never writes to Cursor's state tree. -->
		<string>/Library/Application Support/Cursor/</string>
		<!-- v0.26.3: Clawdmeter's own pre-sandbox state — sessions.json,
		     workspaces.json. Users who ran an older non-sandboxed build
		     have 90+ sessions in the real path; without this exception
		     the new sandboxed app writes to the container instead and
		     forgets every prior session. Read-only is enough; the
		     migration writer will live in the container going forward. -->
		<string>/Library/Application Support/Clawdmeter/</string>
		<!-- v0.28.0: ShellRunner.locateBinary needs to read user-local
		     CLI installs (cursor-agent, claude, etc.) from ~/.local/bin/
		     so the Mac app can spawn them. Read-only is enough; we never
		     install or modify binaries on the user's behalf. -->
		<string>/.local/bin/</string>
		<!-- v0.28.0: Cursor agent CLI config + project state. The
		     CursorTokenProvider reads cursor-agent's keychain entries
		     (cursor-access-token / cursor-refresh-token) via the
		     Security framework (not via this entitlement) but future
		     work that reads ~/.cursor/cli-config.json (for plan auth
		     metadata) needs the file-system grant here. -->
		<string>/.cursor/</string>
		<!-- v0.29.4: cursor-agent's actual binary lives under
		     ~/.local/share/cursor-agent/versions/<rev>/cursor-agent;
		     ~/.local/bin/cursor-agent is a symlink to it. The sandbox
		     follows the symlink at exec time, so without this exception
		     the kernel denies execution of the real binary and
		     CursorModelProbe gets back nothing — Settings → Providers
		     → Cursor's model chooser then shows only "Auto" because
		     `cursor-agent list-models` never ran. Read-only is
		     enough: we don't write to the cursor-agent install tree.
		-->
		<string>/.local/share/cursor-agent/</string>
		<!-- v0.29.34: Claude Code's binary moved to
		     ~/.local/share/claude/versions/<ver>; ~/.local/bin/claude is a
		     symlink to it. Same symlink-exec trap as cursor-agent above —
		     without this exception the kernel denies executing the real
		     binary and locateBinary("claude") falls through to "claude CLI
		     not on PATH", breaking session spawn + the Claude provider
		     probe. Read-only is enough; we never modify the install tree. -->
		<string>/.local/share/claude/</string>
	</array>

	<!--
	  v0.29.4: Homebrew install prefixes.

	  Many users install the agent CLIs (codex, claude, gh, git) via
	  npm/Homebrew rather than the personal-install routes under ~/.
	  - Apple Silicon: /opt/homebrew/bin/ + /opt/homebrew/lib/...
	  - Intel:         /usr/local/bin/   + /usr/local/lib/...

	  Without these exceptions, `FileManager.isExecutableFile` returns
	  false for /opt/homebrew/bin/codex even though the file is there
	  and chmod +x. The new-session dialog then reports "Agent CLI not
	  found on PATH: codex" and the Start button is blocked.

	  Read-only is enough: we only need to stat + exec these binaries;
	  installs and upgrades happen via the user's own `brew` / `npm`
	  invocations outside our process.
	-->
	<key>com.apple.security.temporary-exception.files.absolute-path.read-only</key>
	<array>
		<string>/opt/homebrew/</string>
		<string>/usr/local/</string>
	</array>
	<!--
	  v0.29.4: AppleScript automation to Terminal.app.

	  Why: Settings → Providers → Claude Code shows an "Auth via CLI"
	  button that runs `claude /login` in a fresh Terminal window so the
	  user can complete the OAuth handshake. The implementation uses
	  `NSAppleScript` to `tell application "Terminal" / do script "…"`.
	  In a sandboxed app, AppleScript bridges to other apps are blocked
	  by default — the script silently fails with errAEEventNotPermitted
	  (-1743) and the button does nothing.

	  Fix: declare the apple-events entitlement and scope it to Terminal
	  via `com.apple.security.scripting-targets`. On first click macOS
	  prompts the user once for permission ("Clawdmeter wants to control
	  Terminal"). Approved -> AppleScript flows through -> Terminal
	  opens with the install / login script -> user finishes OAuth.

	  Trade-off: narrow. We declare exactly one target (Terminal) so
	  the entitlement can't be used to drive Safari, Mail, or any other
	  app. The user still has to approve the automation prompt — the
	  entitlement only makes the prompt *possible*. Without it the
	  prompt never appears and the script is rejected at the sandbox
	  boundary.
	-->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
	<key>com.apple.security.temporary-exception.apple-events</key>
	<array>
		<string>com.apple.Terminal</string>
	</array>

	<!-- iCloud KV sync — paid Developer Program only. -->
	<!--
	<key>com.apple.developer.icloud-services</key>
	<array><string>CloudKit</string></array>
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array/>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)ai.continuum</string>
	-->
</dict>
</plist>
