<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<!-- v0.29.7: display-only rebrand to "Continuum". CFBundleName +
	     PRODUCT_NAME stay as "Clawdmeter" so the on-disk executable
	     name, bundle identifier (com.clawdmeter.mac), file paths
	     (~/Library/Application Support/Clawdmeter/), App Group, and
	     keychain-access-group prefixes don't drift — existing installs
	     keep their data, paired iPhones stay paired, no migration.
	     CFBundleDisplayName overrides the name shown in Finder, Dock,
	     menu bar, About panel, App Switcher, and the Window title. The
	     full bundle-ID rebrand to com.montaukanalytics.continuum.* is
	     scheduled for Phase 2 when the new Apple Developer Program
	     enrollment under accounts@montaukanalytics.xyz is active. -->
	<key>CFBundleDisplayName</key>
	<string>Continuum</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<!--
	  v0.26.4: Opt OUT of LaunchServices auto-quarantining files we write.

	  Why: Clawdmeter bundles `opencode` (a Bun single-file executable) at
	  Contents/Resources/Vendor/opencode/opencode. On every launch, opencode
	  extracts an ad-hoc-signed `libopentui.dylib` to the app's sandbox tmp
	  dir under a content-hashed name (e.g. `.bbb6fbfdedbffead-00000000.dylib`).
	  By default macOS stamps `com.apple.quarantine: 0086;<ts>;Clawdmeter;`
	  on any executable code a sandboxed app writes — so when opencode then
	  dlopens that dylib, Gatekeeper sees (quarantine xattr) + (ad-hoc
	  signature, no team identifier) + (filename `.bbb6...dylib`) and shows
	  the "Apple could not verify '.bbb6fbfdedbffead-00000000.dylib' is free
	  of malware" alert on every Code-tab session start.

	  Setting LSFileQuarantineEnabled = false tells LaunchServices NOT to
	  auto-quarantine files this app creates. This is the standard opt-out
	  for apps that act as trusted runtime hosts for their own bundled
	  binaries (browsers, IDEs, package managers, language runtimes do
	  this — opencode/Bun/Node all expect it). The app itself remains
	  sandboxed (see ClawdmeterMac-Release.entitlements), so the blast
	  radius of any code we spawn is still bounded by our entitlements;
	  this key only changes the default xattr on freshly-written files.
	-->
	<key>LSFileQuarantineEnabled</key>
	<false/>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 Continuum (Montauk Analytics).</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Continuum records audio for voice dictation in the agent composer (Ctrl+M). Recording only happens while you hold the mic button.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Continuum uses speech recognition to dictate messages into the agent composer (Ctrl+M). Audio is processed on-device when possible.</string>
	<!-- v0.7.7: NSUserActivity Handoff for the iOS Codex resume sheet's
	     "Continue on Mac" button. iPhone advertises an activity with the
	     threadId; macOS receives it via NSApplicationDelegate's continue:
	     and focuses the matching Sessions tab. Works across same-Apple-ID
	     devices on the same Wi-Fi via Continuity — no apple.com domain
	     required (that's only needed for Universal Links). -->
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.clawdmeter.continue-codex-thread</string>
	</array>
</dict>
</plist>
