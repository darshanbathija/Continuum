# Xcode 27: swift-markdown/cmark-gfm still target watchOS 8.0, which the
# watchOS 27 simulator rejects. Propagate Shared.xcconfig when Xcode or
# script phases invoke xcodebuild without an explicit -xcconfig flag.
if [ -z "${XCODE_XCCONFIG_FILE:-}" ]; then
  export XCODE_XCCONFIG_FILE="${SRCROOT:-$(cd "$(dirname "$0")" && pwd)}/Config/Shared.xcconfig"
fi
