<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Same App Group as the host iOS app so the widget can read the
	     snapshots that `UsageStore.write(...)` pushes into UserDefaults
	     on every poll. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.LRL8MRH6B4.ai.continuum</string>
	</array>
</dict>
</plist>
