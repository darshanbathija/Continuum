# Sessions v2 T27 — Clawdmeter release pipeline.
#
# Targets: Mac DMG + iOS Archive (+ Watch embedded) + TestFlight upload.
# Single-source-of-truth for version: apple/project.yml
# (`CURRENT_PROJECT_VERSION` field). The bump_version lane updates the
# yml + regens the .xcodeproj; release lanes never bump on their own.
#
# Common invocations:
#   bundle exec fastlane match_dev      — sync development certs locally
#   bundle exec fastlane build_mac_dmg  — package the local Mac DMG
#   bundle exec fastlane release_mac_sparkle — Developer ID + notarized Sparkle release
#   bundle exec fastlane release        — full release: bumps build, archives Mac,
#                                          archives iOS, uploads to TestFlight,
#                                          drafts a GitHub release with the DMG.
#
# Required env vars for `release`:
#   CLAWDMETER_APPLE_ID                       Apple ID email
#   CLAWDMETER_TEAM_ID                        10-char Developer team ID
#   CLAWDMETER_MATCH_REPO_URL                 git URL of the certs repo
#   CLAWDMETER_APP_STORE_CONNECT_API_KEY_PATH path to .p8 (CI-friendly,
#                                             no 2FA prompt). Optional in dev.
#   CLAWDMETER_GH_RELEASE_TOKEN               GitHub PAT with `contents: write`
#                                             scope for the public repo.

fastlane_version "2.219.0"
default_platform :ios

# ---------------------------------------------------------------------
# Shared helpers
# ---------------------------------------------------------------------

# Read CURRENT_PROJECT_VERSION from apple/project.yml. This is the
# source of truth for the build number; matches what /ship's version
# bump logic already targets.
def current_build_number
  yml = File.read("../project.yml")
  match = yml.match(/CURRENT_PROJECT_VERSION:\s*"(\d+)"/)
  raise "Could not parse CURRENT_PROJECT_VERSION from project.yml" unless match
  match[1].to_i
end

def current_marketing_version
  yml = File.read("../project.yml")
  match = yml.match(/MARKETING_VERSION:\s*"([^"]+)"/)
  raise "Could not parse MARKETING_VERSION from project.yml" unless match
  match[1]
end

# Write a new build number back to project.yml and re-run xcodegen so
# the .xcodeproj picks it up. Release lanes call this before archiving.
def bump_build_number(new_build)
  path = "../project.yml"
  yml = File.read(path)
  yml.sub!(/CURRENT_PROJECT_VERSION:\s*"\d+"/, %(CURRENT_PROJECT_VERSION: "#{new_build}"))
  File.write(path, yml)
  sh("cd .. && xcodegen")
end

# ---------------------------------------------------------------------
# Cert / profile sync
# ---------------------------------------------------------------------

platform :ios do
  desc "Sync development certs + profiles for all 5 targets."
  lane :match_dev do
    match(type: "development")
  end

  desc "Sync App Store certs + profiles. Run before `release`."
  lane :match_release do
    match(type: "appstore")
  end
end

# ---------------------------------------------------------------------
# Mac DMG build
# ---------------------------------------------------------------------

desc "Package the Mac app into a local DMG. Sparkle publishing uses release_mac_sparkle."
lane :build_mac_dmg do
  build = current_build_number
  market = current_marketing_version
  UI.message "Packaging Mac DMG for v#{market} (build #{build})"
  sh("cd ../.. && ./tools/build-mac-dmg.sh")
  UI.success "Mac DMG built. Look in dist/."
end

desc "Credential-gated Mac release: Developer ID, notarization, GitHub asset, Pages appcast."
lane :release_mac_sparkle do
  UI.header "Running Sparkle Mac release path"
  sh("cd ../.. && ./tools/release-mac.sh --publish")
end

# ---------------------------------------------------------------------
# iOS archive + TestFlight
# ---------------------------------------------------------------------

platform :ios do
  desc "Archive the iOS app + Watch extension and upload to TestFlight.
The Watch app rides along in the same .xcarchive since it's embedded
in the iOS bundle."
  lane :ios_testflight do
    match(type: "appstore", readonly: true)
    build_app(
      project: "Clawdmeter.xcodeproj",
      scheme: "Clawdmeter (iOS)",
      destination: "generic/platform=iOS",
      output_directory: "./build",
      output_name: "Clawdmeter-iOS.ipa",
      include_symbols: true,
      include_bitcode: false
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      api_key_path: ENV["CLAWDMETER_APP_STORE_CONNECT_API_KEY_PATH"]
    )
  end
end

# ---------------------------------------------------------------------
# Full release lane
# ---------------------------------------------------------------------

desc "Full release: bump build number, run Sparkle Mac release, ship iOS TestFlight."
lane :release do
  ensure_git_status_clean(show_uncommitted_changes: true)
  build = current_build_number + 1
  market = current_marketing_version
  UI.header "Releasing v#{market} (build #{build})"

  bump_build_number(build)

  # Commit the bump so the release lane can reference a clean SHA.
  sh("git add ../project.yml ../Clawdmeter.xcodeproj && git commit -m 'release: bump build to #{build}'")

  # Mac release. This is the only supported public Mac release path.
  release_mac_sparkle

  # iOS + Watch → TestFlight.
  Fastlane::LaneManager.cruise_lane("ios", "ios_testflight")

  UI.success "Release v#{market} build #{build} completed for Mac Sparkle path and TestFlight upload is in flight."
end

# ---------------------------------------------------------------------
# v27 Continuum TestFlight pipeline (App Store Connect API key auth)
# ---------------------------------------------------------------------

# Load the App Store Connect API key from env (key id / issuer id / .p8 path).
# Sets the lane-context token so produce / gym / pilot reuse it without a 2FA
# prompt. Returns the api_key hash for explicit `api_key:` args.
def continuum_asc_key
  app_store_connect_api_key(
    key_id: ENV["CLAWDMETER_ASC_KEY_ID"],
    issuer_id: ENV["CLAWDMETER_ASC_ISSUER_ID"],
    key_filepath: ENV["CLAWDMETER_ASC_KEY_PATH"],
    duration: 1200,
    in_house: false
  )
end

desc "Read-only: verify the ASC API key auths + list existing apps."
lane :asc_verify do
  continuum_asc_key
  apps = Spaceship::ConnectAPI::App.all
  if apps.empty?
    UI.important "API key OK. No apps exist yet under this team."
  else
    UI.success "API key OK. #{apps.size} app(s): #{apps.map { |a| a.bundle_id }.join(', ')}"
  end
end

desc "Probe whether a bundle-id prefix is available (creates PROBE_ID)."
lane :probe_prefix do
  continuum_asc_key
  id = ENV["PROBE_ID"]
  begin
    Spaceship::ConnectAPI::BundleId.create(
      name: id.tr(".", " "), identifier: id,
      platform: Spaceship::ConnectAPI::BundleIdPlatform::IOS
    )
    UI.success "AVAILABLE (created): #{id}"
  rescue => e
    UI.error "NOT available: #{id} :: #{e.message.gsub(/\s+/, ' ')[0, 200]}"
  end
end

desc "Pre-create the 6 App IDs via the App Store Connect API (the API key path
that works headlessly — fastlane's own App-ID creation needs a portal login).
Best-effort capabilities so the app-store profiles carry the entitlements."
lane :continuum_bootstrap_ids do
  continuum_asc_key
  ios = Spaceship::ConnectAPI::BundleIdPlatform::IOS
  mac = Spaceship::ConnectAPI::BundleIdPlatform::MAC_OS
  specs = [
    ["ai.continuum.ios",          ios, "Continuum iOS"],
    ["ai.continuum.ios.widgets",  ios, "Continuum iOS Widgets"],
    ["ai.continuum.watch",        ios, "Continuum Watch"],
    ["ai.continuum.watch.widgets",ios, "Continuum Watch Widgets"],
    ["ai.continuum.mac",          mac, "Continuum Mac"],
    ["ai.continuum.mac.widgets",  mac, "Continuum Mac Widgets"],
  ]
  existing = Spaceship::ConnectAPI::BundleId.all.map(&:identifier)
  specs.each do |identifier, platform, name|
    if existing.include?(identifier)
      UI.message "exists: #{identifier}"
    else
      Spaceship::ConnectAPI::BundleId.create(name: name, identifier: identifier, platform: platform)
      UI.success "created App ID: #{identifier}"
    end
  end
  UI.success "App IDs ready."
end

desc "Sync App Store distribution cert + profiles for all bundle IDs (API key
auth via match; app-store profiles need no devices)."
lane :continuum_match do
  key = continuum_asc_key
  match(api_key: key, type: "appstore", readonly: false)
  UI.success "match appstore synced."
end

desc "Read-only: confirm the API key can reach Certificates/IDs/Profiles."
lane :asc_check_devportal do
  continuum_asc_key
  begin
    certs = Spaceship::ConnectAPI::Certificate.all
    bundles = Spaceship::ConnectAPI::BundleId.all
    UI.success "Dev-portal OK. certs=#{certs.size} bundleIds=#{bundles.size}"
    UI.message "certs: #{certs.map { |c| c.certificate_type }.join(', ')}"
    UI.message "bundleIds: #{bundles.map { |b| b.identifier }.join(', ')}"
    apps = Spaceship::ConnectAPI::App.all
    UI.message "apps: #{apps.map { |a| a.bundle_id }.join(', ')}"
  rescue => e
    UI.error "Dev-portal access FAILED (key role likely too low — needs Admin): #{e.class}: #{e.message}"
  end
end

desc "Create the iOS App Store Connect app record (ASC API key — no dev-center
login). Requires the App ID to already exist (created by the archive's
-allowProvisioningUpdates). Idempotent."
lane :continuum_produce do
  continuum_asc_key  # sets the lane-context ASC API token produce reuses
  produce(
    app_identifier: "ai.continuum.ios",
    app_name: ENV["CONTINUUM_APP_NAME"] || "Continuum",
    language: "English",
    sku: "continuum-ios-001",
    team_id: ENV["CLAWDMETER_TEAM_ID"],
    company_name: "Montauk Analytics Inc",
    skip_itc: false,
    skip_devcenter: true,
    platform: "ios"
  )
  UI.success "iOS App Store Connect record ready."
end

desc "Archive iOS + Watch only (Xcode-managed automatic signing + API key)."
lane :continuum_archive do
  continuum_asc_key  # sets lane-context token (used by produce/pilot later)
  # Pass the ASC API key straight to xcodebuild so -allowProvisioningUpdates
  # can create the cert/profiles/App-IDs/capabilities headlessly (no 2FA).
  auth = "-authenticationKeyPath #{ENV['CLAWDMETER_ASC_KEY_PATH']} " \
         "-authenticationKeyID #{ENV['CLAWDMETER_ASC_KEY_ID']} " \
         "-authenticationKeyIssuerID #{ENV['CLAWDMETER_ASC_ISSUER_ID']}"
  sh("cd .. && xcodegen >/dev/null")
  build_app(
    project: "Clawdmeter.xcodeproj",
    scheme: "Clawdmeter (iOS)",
    destination: "generic/platform=iOS",
    export_method: "app-store",
    output_directory: "./build",
    output_name: "Continuum-iOS.ipa",
    include_symbols: true,
    xcargs: "-allowProvisioningUpdates #{auth}",
    export_xcargs: "-allowProvisioningUpdates #{auth}"
  )
  UI.success "iOS + Watch archived → ./build/Continuum-iOS.ipa"
end

desc "Full iOS TestFlight: archive (auto-provision) → app record → upload."
lane :continuum_ios_testflight do
  continuum_archive
  continuum_produce
  continuum_asc_key  # re-assert the lane-context token for pilot
  upload_to_testflight(
    skip_waiting_for_build_processing: true,
    ipa: "./build/Continuum-iOS.ipa"
  )
  UI.success "iOS + Watch uploaded to TestFlight."
end
