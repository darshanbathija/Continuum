<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Shared with ClawdmeterWatchWidgets so complications can read the
	     latest snapshot from UserDefaults under this suite. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.LRL8MRH6B4.ai.continuum</string>
	</array>
	<!-- Shared iCloud-Keychain access group: the Mac mirrors Claude Code's
	     OAuth token here and the Watch reads it on first launch — no manual
	     token paste required. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)ai.continuum</string>
	</array>
</dict>
</plist>
